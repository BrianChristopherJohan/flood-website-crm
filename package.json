{
  "name": "flood-management-crm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --max-http-header-size=65536 node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "start-server-and-test dev http://localhost:3000 cy:run",
    "test:e2e:open": "start-server-and-test dev http://localhost:3000 cy:open",
    "test:e2e:playwright": "playwright test",
    "test:e2e:playwright:ui": "playwright test --ui",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:headed": "cypress run --headed",
    "cy:run:auth": "cypress run --spec 'cypress/e2e/auth.cy.ts'",
    "cy:run:admin": "cypress run --spec 'cypress/e2e/admin.cy.ts'",
    "cy:run:blogs": "cypress run --spec 'cypress/e2e/blogs.cy.ts'",
    "cy:run:broadcasts": "cypress run --spec 'cypress/e2e/broadcasts.cy.ts'",
    "cy:run:dashboard": "cypress run --spec 'cypress/e2e/dashboard.cy.ts'",
    "cy:run:map": "cypress run --spec 'cypress/e2e/map.cy.ts'",
    "cy:run:sensors": "cypress run --spec 'cypress/e2e/sensors.cy.ts'"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@react-google-maps/api": "^2.20.7",
    "clsx": "^2.1.1",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "next": "16.2.1",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.58.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.8.32",
    "cypress": "^13.17.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "typescript": "^5"
  }
}
