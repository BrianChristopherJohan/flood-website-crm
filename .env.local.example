# flood-website-crm local fallback environment
# Copy to .env.local when running the CRM from this folder.

# Local-only CRM login fallback. Keep this unset/false on Vercel so
# production continues to use the community website login.
CRM_LOCAL_LOGIN=true
ALLOW_PAYLOAD_ONLY_AUTH=true

# CRM Spring Boot API. Use your local backend if running it, or keep the
# Railway URL from .env.example if you only want to run the frontend locally.
JAVA_API_URL=http://localhost:4002
NEXT_PUBLIC_JAVA_API_URL=http://localhost:4002

# Community service and site, used by moderation/UAT routes and production-style login links.
COMMUNITY_JAVA_API_URL=http://localhost:4001
NEXT_PUBLIC_COMMUNITY_URL=http://localhost:3002

# Flood AI Prediction FastAPI service.
AI_API_URL=http://localhost:8000

# Public FloodWatch IoT API. sample gives stable demo nodes for map/dashboard.
FLOODWATCH_API_BASE=http://159.223.70.28/api/v1
FLOODWATCH_DATASET=sample

# Required for the live Google map. Without this, the app shows a map preview.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Optional local Redis/JWT hardening values.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
JWT_SECRET=
